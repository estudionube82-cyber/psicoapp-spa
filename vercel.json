{
  "routes": [
    { "src": "/(.+\\.js)",   "dest": "/$1" },
    { "src": "/(.+\\.css)",  "dest": "/$1" },
    { "src": "/(.+\\.png)",  "dest": "/$1" },
    { "src": "/(.+\\.json)", "dest": "/$1" },
    { "src": "/(.+\\.html)", "dest": "/$1" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ]
}
